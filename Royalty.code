from flask import Flask, jsonify, request, render_template_string
import hashlib, urllib.request, urllib.parse, json as json_mod, re, os

app = Flask(__name__)
_LOOKUP_CACHE = {}
_TRACK_CACHE  = {}

# ── Scoring ───────────────────────────────────────────────────────────────────
def score_album(al):
    s = 100
    p = al["psr_multiple"]
    s -= 0 if p < 12 else 8 if p < 16 else 18 if p < 20 else 30 if p < 24 else 40
    t = al["stream_trend_3yr"]
    g = (t[-1] - t[0]) / t[0] if t[0] else 0
    s -= 0 if g > .15 else 8 if g > .05 else 16 if g > 0 else 30
    sy = al["sync_placements"]
    s -= 0 if sy > 1000 else 4 if sy > 500 else 9 if sy > 200 else 15
    ps = al["publishing_pct"] + al["sync_pct"]
    s -= 0 if ps > 70 else 4 if ps > 55 else 9 if ps > 40 else 15
    return max(0, min(100, s))

def verdict(score):
    if score >= 78: return {"label":"STRONG BUY","color":"green","icon":"▲"}
    if score >= 62: return {"label":"BUY","color":"teal","icon":"▲"}
    if score >= 48: return {"label":"MONITOR","color":"yellow","icon":"◆"}
    if score >= 35: return {"label":"PASS","color":"orange","icon":"▼"}
    return {"label":"STRONG PASS","color":"red","icon":"▼"}

# ── Deterministic helpers ─────────────────────────────────────────────────────
def _sv(seed, lo, hi, d=1):
    n = int(hashlib.md5(str(seed).encode()).hexdigest(), 16)
    return round(lo + (n % 100_000) / 100_000 * (hi - lo), d)
def _si(seed, lo, hi): return int(_sv(seed, lo, hi, 0))

_GENRE_SPLITS = {
    "hip-hop":(30,12,58),"rap":(28,10,62),"r&b":(46,24,30),"soul":(50,28,22),
    "pop":(38,22,40),"rock":(52,28,20),"alternative":(48,26,26),"indie":(52,28,20),
    "folk":(58,32,10),"country":(52,26,22),"jazz":(60,34,6),"electronic":(32,16,52),
}
def _gsplit(g):
    g = g.lower()
    for k, v in _GENRE_SPLITS.items():
        if k in g: return v
    return (42, 22, 36)

# ── iTunes fetch ──────────────────────────────────────────────────────────────
NOISE = re.compile(
    r'live\b|karaoke|tribute|instrumental|soundtrack|score|\bost\b|'
    r'the musical|the series|disney|nickelodeon|christmas|holiday|'
    r'video album|sollos|remixes\b|greatest hits|best of\b|collection\b|anthology|compil',
    re.IGNORECASE)

def _base(name):
    n = re.sub(r'\s*[\(\[]?\s*(deluxe|expanded|special|bonus|platinum|anniversary|'
               r'reissue|extended|complete|super deluxe)[^\)\]]*[\)\]]?', '', name, flags=re.IGNORECASE)
    return re.sub(r'\s*\(.*?\)\s*$', '', n, flags=re.IGNORECASE).strip().lower()

def _estimate(a, genre):
    aid = a["collectionId"]
    year = int(a.get("releaseDate","2020")[:4])
    tracks = a.get("trackCount", 10)
    age = max(0, 2025 - year)
    psr = _sv(aid^(5 if age<=3 else 4 if age<=8 else 3 if age<=15 else 2 if age<=25 else 1),
              18 if age<=3 else 14.8 if age<=8 else 12.2 if age<=15 else 10.4 if age<=25 else 7.8,
              28 if age<=3 else 22.6 if age<=8 else 18.4 if age<=15 else 15.8 if age<=25 else 12.5)
    rev_K = max(50, int(tracks * _sv(aid^6,18,180,0) * max(0.1, 1-age*.018)))
    sync_pl = _si(aid^7,30,600) + int(age * _sv(aid^8,4,48,0))
    bs = _sv(aid^9, 0.8, max(1.2, 40-age*0.6), 1)
    dr = _sv(aid^10, -0.18, 0.32, 3)
    trend = [round(max(0.1, bs),1), round(max(0.1, bs*(1+dr*.5)),1), round(max(0.1, bs*(1+dr)),1)]
    pub, sync, rec = _gsplit(genre)
    j = _si(aid^11, -5, 5)
    pub = max(20, min(70, pub+j)); sync = max(8, min(40, sync-j//2)); rec = 100-pub-sync
    g = trend[2] >= trend[0]; pct = abs(round((trend[2]-trend[0])/trend[0]*100))
    note = (f"Below fair-value ({psr}×). {'Growing +'+str(pct)+'%' if g else 'Flat streams'} — potential entry."
            if psr < 12 else f"Fair-value ({psr}×). {'Growth +'+str(pct)+'%' if g else 'Stable'}." if psr < 17
            else f"Premium ({psr}×). {'Justified by +'+str(pct)+'%' if g else 'Monitor stream decline'}." if psr < 22
            else f"Expensive {psr}×. {'High growth' if g else 'Declining — avoid'}.")
    return {"itunes_id":aid,"title":a["collectionName"],"year":year,"tracks":tracks,
            "annual_revenue_K":rev_K,"psr_multiple":psr,"publishing_pct":pub,"sync_pct":sync,
            "recording_pct":rec,"stream_trend_3yr":trend,"sync_placements":sync_pl,"notes":note}

def _fetch_itunes(name):
    try:
        q = urllib.parse.quote(name)
        with urllib.request.urlopen(f"https://itunes.apple.com/search?term={q}&entity=musicArtist&limit=5&media=music", timeout=10) as r:
            sr = json_mod.loads(r.read().decode())
        if not sr.get("resultCount"): return None
        ar = sr["results"][0]
        aid, aname, genre = ar["artistId"], ar["artistName"], ar.get("primaryGenreName","Pop")
        with urllib.request.urlopen(f"https://itunes.apple.com/lookup?id={aid}&entity=album&limit=200", timeout=10) as r:
            ad = json_mod.loads(r.read().decode())
        raw = [x for x in ad["results"] if x.get("wrapperType")=="collection"
               and x.get("artistId")==aid and x.get("trackCount",0)>1
               and not NOISE.search(x.get("collectionName",""))]
        groups = {}
        for a in raw:
            k = _base(a.get("collectionName",""))
            groups.setdefault(k,[]).append(a)
        deduped = []
        for vs in groups.values():
            if len(vs)==1: deduped.append(vs[0]); continue
            vs.sort(key=lambda x: x.get("releaseDate",""))
            best = max(vs, key=lambda x: x.get("trackCount",0))
            deduped.append(best if best.get("trackCount",0) > vs[0].get("trackCount",0)+4 else vs[0])
        albums_raw = sorted(deduped, key=lambda x: x.get("releaseDate",""))
        if not albums_raw: return None
        albums_out = []
        for al in albums_raw:
            e = _estimate(al, genre)
            s = score_album(e); e["score"]=s; e["verdict"]=verdict(s)
            albums_out.append(e)
        avg = round(sum(a["score"] for a in albums_out)/len(albums_out))
        initials = "".join(w[0].upper() for w in aname.split()[:2])
        return {"key":aname.lower().replace(" ","-"),"name":aname,"genre":[genre],
                "active_years":f"{albums_raw[0].get('releaseDate','????')[:4]}–present",
                "catalog_size":sum(a.get("trackCount",0) for a in albums_raw),
                "monthly_streams_M":round(_sv(aid^99,0.8,95.0),1),
                "image_placeholder":initials,"independent":False,
                "label":"See iTunes / Streaming Platforms",
                "bio":f"Live data from iTunes. {len(albums_out)} releases found. PSR figures are modeled estimates.",
                "simulated":True,"itunes_artist_id":aid,"albums":albums_out,
                "overall_score":avg,"overall_verdict":verdict(avg)}
    except Exception as e:
        app.logger.error(f"iTunes error '{name}': {e}"); return None

