# ── Routes ────────────────────────────────────────────────────────────────────
@app.route("/")
def index():
    return render_template_string(HTML)

@app.route("/api/artists")
def list_artists():
    out = []
    for key, a in ARTISTS.items():
        scores = [score_album(al) for al in a["albums"]]
        avg = round(sum(scores)/len(scores))
        out.append({"key":key,"name":a["name"],"genre":a["genre"],
                    "monthly_streams_M":a["monthly_streams_M"],"catalog_size":a["catalog_size"],
                    "album_count":len(a["albums"]),"image_placeholder":a["image_placeholder"],
                    "independent":a.get("independent",False),"label":a.get("label",""),
                    "avg_score":avg,"verdict":verdict(avg)})
    out.sort(key=lambda x:(x["independent"],x["avg_score"]),reverse=True)
    return jsonify(out)

@app.route("/api/artist/<key>")
def get_artist(key):
    a = ARTISTS.get(key)
    if not a: return jsonify({"error":"not found"}),404
    albums = [{**al,"score":score_album(al),"verdict":verdict(score_album(al))} for al in a["albums"]]
    avg = round(sum(x["score"] for x in albums)/len(albums))
    return jsonify({**a,"key":key,"simulated":False,"albums":albums,"overall_score":avg,"overall_verdict":verdict(avg)})

@app.route("/api/search")
def search():
    q = request.args.get("q","").lower().strip()
    out = []
    for key, a in ARTISTS.items():
        if q in a["name"].lower() or any(q in g.lower() for g in a["genre"]):
            scores = [score_album(al) for al in a["albums"]]
            avg = round(sum(scores)/len(scores))
            out.append({"key":key,"name":a["name"],"genre":a["genre"],
                        "image_placeholder":a["image_placeholder"],"independent":a.get("independent",False),
                        "avg_score":avg,"verdict":verdict(avg),"simulated":False})
    return jsonify(out)

@app.route("/api/lookup")
def lookup():
    name = request.args.get("name","").strip()
    if not name: return jsonify({"error":"name required"}),400
    slug = name.lower().replace(" ","-")
    if slug in ARTISTS: return get_artist(slug)
    ck = name.lower()
    if ck in _LOOKUP_CACHE: return jsonify(_LOOKUP_CACHE[ck])
    profile = _fetch_itunes(name)
    if not profile:
        return jsonify({"error":f"Artist '{name}' not found"}),404
    _LOOKUP_CACHE[ck] = profile
    return jsonify(profile)

def _parse_tracks(results):
    tracks = []
    for item in results:
        if item.get("wrapperType")=="track" and item.get("kind")=="song":
            ms = item.get("trackTimeMillis",0)
            tracks.append({"number":item.get("trackNumber",0),"name":item.get("trackName","Unknown"),
                           "duration":f"{ms//60000}:{(ms%60000)//1000:02d}" if ms else "—",
                           "preview":item.get("previewUrl","")})
    return sorted(tracks, key=lambda t: t["number"])

@app.route("/api/album_tracks")
def album_tracks():
    aid = request.args.get("id","").strip()
    if not aid: return jsonify([])
    if aid in _TRACK_CACHE: return jsonify(_TRACK_CACHE[aid])
    try:
        with urllib.request.urlopen(f"https://itunes.apple.com/lookup?id={aid}&entity=song",timeout=10) as r:
            data = json_mod.loads(r.read().decode())
        tracks = _parse_tracks(data.get("results",[]))
        _TRACK_CACHE[aid] = tracks
        return jsonify(tracks)
    except: return jsonify([])

@app.route("/api/album_tracks_by_name")
def album_tracks_by_name():
    artist = request.args.get("artist","").strip()
    album  = request.args.get("album","").strip()
    if not artist or not album: return jsonify([])
    ck = f"{artist.lower()}::{album.lower()}"
    if ck in _TRACK_CACHE: return jsonify(_TRACK_CACHE[ck])
    try:
        q = urllib.parse.quote(f"{artist} {album}")
        with urllib.request.urlopen(f"https://itunes.apple.com/search?term={q}&entity=album&limit=10&media=music",timeout=10) as r:
            sr = json_mod.loads(r.read().decode())
        results = sr.get("results",[])
        if not results: return jsonify([])
        best = max(results, key=lambda r: len(set(r.get("collectionName","").lower().split()) & set(album.lower().split())))
        aid = best["collectionId"]
        with urllib.request.urlopen(f"https://itunes.apple.com/lookup?id={aid}&entity=song",timeout=10) as r:
            data = json_mod.loads(r.read().decode())
        tracks = _parse_tracks(data.get("results",[]))
        _TRACK_CACHE[ck] = tracks; _TRACK_CACHE[str(aid)] = tracks
        return jsonify(tracks)
    except: return jsonify([])

